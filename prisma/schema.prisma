generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model change_log {
  id                                  String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  einsatz_id                          String?     @db.Uuid
  user_id                             String?     @db.Uuid
  type_id                             String      @db.Uuid
  created_at                          DateTime    @default(now())
  affected_user                       String?     @db.Uuid
  user_change_log_affected_userTouser user?       @relation("change_log_affected_userTouser", fields: [affected_user], references: [id])
  einsatz                             einsatz?    @relation(fields: [einsatz_id], references: [id])
  change_type                         change_type @relation(fields: [type_id], references: [id], onDelete: NoAction)
  user                                user?       @relation(fields: [user_id], references: [id])

  @@index([einsatz_id, created_at])
  @@index([user_id, created_at])
  @@index([affected_user, created_at])
  @@index([created_at])
  @@index([einsatz_id, type_id])
}

model change_type {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String       @unique
  message         String
  change_icon_url String
  change_color    String
  change_log      change_log[]
}

model einsatz {
  id                    String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title                 String
  created_at            DateTime                @default(now())
  updated_at            DateTime?
  start                 DateTime                @db.Timestamp(6)
  participant_count     Int?
  price_per_person      Float?
  total_price           Float?
  org_id                String                  @db.Uuid
  created_by            String?                 @db.Uuid
  template_id           String?                 @db.Uuid
  all_day               Boolean                 @default(false)
  end                   DateTime                @db.Timestamp(6)
  helpers_needed        Int                     @default(1) @db.SmallInt
  status_id             String                  @default(dbgenerated("'bb169357-920b-4b49-9e3d-1cf489409370'::uuid")) @db.Uuid
  anmerkung             String?
  change_log            change_log[]
  user                  user?                   @relation(fields: [created_by], references: [id], onDelete: Cascade)
  organization          organization            @relation(fields: [org_id], references: [id], onDelete: Cascade)
  einsatz_status        einsatz_status          @relation(fields: [status_id], references: [id], onDelete: Cascade)
  einsatz_template      einsatz_template?       @relation(fields: [template_id], references: [id])
  einsatz_comment       einsatz_comment[]
  einsatz_field         einsatz_field[]
  einsatz_helper        einsatz_helper[]
  einsatz_to_category   einsatz_to_category[]
  einsatz_user_property einsatz_user_property[]

  @@index([org_id, start])
  @@index([org_id, status_id])
  @@index([created_by])
  @@index([template_id])
}

model einsatz_category {
  value                String
  id                   String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  abbreviation         String                 @default("")
  org_id               String                 @db.Uuid
  organization         organization           @relation(fields: [org_id], references: [id], onDelete: Cascade)
  einsatz_to_category  einsatz_to_category[]
  template_to_category template_to_category[]

  @@index([org_id, value])
}

model einsatz_comment {
  created_at DateTime @default(now())
  einsatz_id String   @db.Uuid
  user_id    String   @db.Uuid
  comment    String
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  einsatz    einsatz  @relation(fields: [einsatz_id], references: [id], onDelete: Cascade)
  user       user     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model einsatz_helper {
  einsatz_id String   @db.Uuid
  user_id    String   @db.Uuid
  joined_at  DateTime @default(now())
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id     String   @db.Uuid
  einsatz    einsatz  @relation(fields: [einsatz_id], references: [id], onDelete: Cascade)
  user       user     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([einsatz_id])
  @@index([user_id])
  @@index([org_id], map: "idx_einsatz_helper_org_id")
  @@index([org_id, einsatz_id], map: "idx_einsatz_helper_org_id_einsatz_id")
}

model einsatz_template {
  id                            String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id                        String                   @db.Uuid
  name                          String
  created_by                    String?                  @db.Uuid
  created_at                    DateTime                 @default(now())
  description                   String?
  icon_id                       String                   @default(dbgenerated("'17effde3-bacb-4cd9-9303-c0467a6e437b'::uuid")) @db.Uuid
  participant_count_default     Int?                     @db.SmallInt
  participant_count_placeholder Int?                     @default(20) @db.SmallInt
  price_person_default          Float?                   @db.Real
  price_person_placeholder      Float?                   @db.Real
  helpers_needed_default        Int?                     @db.SmallInt
  helpers_needed_placeholder    Int?                     @default(1) @db.SmallInt
  all_day_default               Boolean?
  is_paused                     Boolean                  @default(false)
  anmerkung_default             String?
  anmerkung_placeholder         String?
  total_price_default           Float?                   @db.Real
  total_price_placeholder       Float?                   @db.Real
  time_start_default            DateTime?                @db.Time(6)
  time_end_default              DateTime?                @db.Time(6)
  einsatzname_default           String?
  einsatzname_placeholder       String?
  einsatz                       einsatz[]
  user                          user?                    @relation(fields: [created_by], references: [id], onDelete: Cascade)
  template_icon                 template_icon            @relation(fields: [icon_id], references: [id], onDelete: Cascade)
  organization                  organization             @relation(fields: [org_id], references: [id], onDelete: Cascade)
  template_field                template_field[]
  template_to_category          template_to_category[]
  template_user_property        template_user_property[]

  @@index([org_id, is_paused, name])
}

model organization {
  id                                        String                                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                                      String                                      @unique
  logo_url                                  String?
  description                               String?
  helper_name_singular                      String?                                     @default("Vermittler:in")
  helper_name_plural                        String?                                     @default("Vermittler:innen")
  created_at                                DateTime                                    @default(now())
  updated_at                                DateTime?
  einsatz_name_singular                     String                                      @default("Einsatz")
  einsatz_name_plural                       String                                      @default("Einsätze")
  email                                     String?
  phone                                     String?
  helferansicht_description                 String?
  verwalteransicht_description              String?
  abbreviation                              String?
  max_participants_per_helper               Int?                                        @default(25) @db.SmallInt
  allow_self_sign_out                       Boolean                                     @default(false) @map("allow_self-sign-out")
  default_starttime                         DateTime                                    @default(dbgenerated("'09:00:00'::time without time zone")) @map("default-starttime") @db.Time(6)
  default_endtime                           DateTime                                    @default(dbgenerated("'10:00:00'::time without time zone")) @map("default-endtime") @db.Time(6)
  small_logo_url                            String?                                     @map("small-logo_url")
  trial_starts_at                           DateTime                                    @default(now()) @db.Timestamptz(6)
  trial_ends_at                             DateTime?                                   @db.Timestamptz(6)
  subscription_status                       String                                      @default("trial")
  analytics_chart                           analytics_chart[]
  calendar_subscription                     calendar_subscription[]
  einsatz                                   einsatz[]
  einsatz_category                          einsatz_category[]
  einsatz_template                          einsatz_template[]
  invitation                                invitation[]
  notification_email_digest_queue           notification_email_digest_queue[]
  organization_address                      organization_address[]
  organization_bank_account                 organization_bank_account[]
  organization_details                      organization_details[]
  organization_notification_settings        organization_notification_settings?
  pdfTemplate                               pdfTemplate[]
  user                                      user[]
  user_organization_notification_preference user_organization_notification_preference[]
  user_organization_role                    user_organization_role[]
  user_property                             user_property[]

  @@index([name])
}

model type {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String?
  description String?
  icon_url    String?
  sort_order  Int?    @db.SmallInt
  datatype    String  @unique
  field       field[]
}

model user {
  id                                        String                                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                                     String                                      @unique
  firstname                                 String
  lastname                                  String
  password                                  String
  phone                                     String?
  created_at                                DateTime                                    @default(now())
  updated_at                                DateTime?
  picture_url                               String?
  description                               String?
  last_login                                DateTime?                                   @db.Timestamp(6)
  hasLogoinCalendar                         Boolean                                     @default(true)
  last_read_notifications                   DateTime?                                   @db.Timestamptz(6)
  resetToken                                String?
  resetTokenExpires                         DateTime?                                   @db.Timestamp(6)
  salutationId                              String?                                     @db.Uuid
  active_org                                String?                                     @map("active-org") @db.Uuid
  analytics_chart                           analytics_chart[]
  calendar_subscription                     calendar_subscription[]
  change_log_change_log_affected_userTouser change_log[]                                @relation("change_log_affected_userTouser")
  change_log                                change_log[]
  einsatz                                   einsatz[]
  einsatz_comment                           einsatz_comment[]
  einsatz_helper                            einsatz_helper[]
  einsatz_template                          einsatz_template[]
  invitation                                invitation[]
  notification_email_digest_queue           notification_email_digest_queue[]
  organization                              organization?                               @relation(fields: [active_org], references: [id])
  salutation                                salutation?                                 @relation(fields: [salutationId], references: [id], onDelete: Restrict)
  user_organization_notification_preference user_organization_notification_preference[]
  user_organization_role                    user_organization_role[]
  user_property_value                       user_property_value[]
  user_session                              user_session[]
}

model user_organization_role {
  id                     String       @id(map: "user_organization_rol_pkey") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                String       @db.Uuid
  org_id                 String       @db.Uuid
  created_at             DateTime     @default(now()) @db.Timestamptz(6)
  role_id                String       @db.Uuid
  hasGetMailNotification Boolean?
  organization           organization @relation(fields: [org_id], references: [id], onDelete: Cascade)
  role                   role         @relation(fields: [role_id], references: [id], onDelete: NoAction)
  user                   user         @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([org_id, role_id])
  @@index([org_id, user_id])
  @@index([user_id, org_id])
}

model user_property {
  id                     String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  field_id               String                   @db.Uuid
  org_id                 String                   @db.Uuid
  einsatz_user_property  einsatz_user_property[]
  template_user_property template_user_property[]
  field                  field                    @relation(fields: [field_id], references: [id], onDelete: Cascade)
  organization           organization             @relation(fields: [org_id], references: [id], onDelete: Cascade)
  user_property_value    user_property_value[]

  @@index([org_id, field_id])
  @@index([org_id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model invitation {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String
  token        String
  created_at   DateTime     @default(now()) @db.Timestamptz(6)
  expires_at   DateTime     @db.Timestamp(6)
  invited_by   String       @db.Uuid
  accepted     Boolean      @default(false)
  org_id       String       @db.Uuid
  role_id      String       @db.Uuid
  new_user_id  String       @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user         user         @relation(fields: [invited_by], references: [id], onDelete: Cascade)
  organization organization @relation(fields: [org_id], references: [id], onDelete: Cascade)
  role         role         @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@index([org_id, accepted])
  @@index([email, org_id, accepted, expires_at])
  @@index([token])
}

